KV_REST_API_URL=https://<your-upstash-rest-url>
KV_REST_API_TOKEN=<your-upstash-rest-token>
KV_REST_API_READ_ONLY_TOKEN=<optional-read-only-token>

# If you prefer Upstash default env names, you can use these instead:
# UPSTASH_REDIS_REST_URL=https://<your-upstash-rest-url>
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
